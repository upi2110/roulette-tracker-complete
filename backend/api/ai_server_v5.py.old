    print("  ✅ Bankroll rule: < $3000 = golden patterns only")
    print()
    print("Discipline: Maximum selectivity for consistent profit!")
    print("Goal: $1000/day with 75-85% win rate")
    print("=" * 70)
    print()
    
    uvicorn.run(app, host="127.0.0.1", port=8000, log_level="info")
