"""
AI Engine V6 - NEW STRATEGY
============================

New prediction methodology:
1. Find pairs with 2+ consecutive hits from Table 3
2. Select top 2 pairs with most consecutive hits
3. Get NEXT row projections for those pairs
4. Find common numbers between the projections
5. Filter to 12 using Table 1 & 2 if needed
6. Return both filtered (12) and full pool

Key differences from V5:
- Uses NEXT row projections (white boxes) NOT historical anchor pool
- Common numbers from top 2 pairs
- Table 1 & 2 filtering (0+19 as one pair)
- Priority patterns: S+0, S±1, O+0, O±1
"""

import logging
from typing import Dict, List, Set, Tuple, Optional
from datetime import datetime

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='[%(asctime)s.%(msecs)03d] [%(levelname)s] %(message)s',
    datefmt='%H:%M:%S'
)

class AIEngineV6:
    """
    New prediction engine implementing the refined strategy
    """
    
    def __init__(self):
        self.consecutive_losses = 0
        self.consecutive_wins = 0
        self.total_session_loss = 0.0  # NEW!
        
        # Priority patterns (highest priority)
        # Includes ±1 as golden patterns
        self.GOLDEN_PATTERNS = ['S+0', 'S+1', 'S-1', 'O+0', 'O+1', 'O-1']  # UPDATED!
        self.HIGH_PRIORITY_PATTERNS = ['S+0', 'S+1', 'S-1', 'O+0', 'O+1', 'O-1']
        
    def predict(self, table_data: Dict) -> Dict:
        """
        Main prediction function using new strategy
        
        Args:
            table_data: {
                'table3Hits': Historical hits from Table 3
                'table3NextProjections': Projections for NEXT spin (NEW!)
                'table1Hits': Historical hits from Table 1
                'table2Hits': Historical hits from Table 2
                'currentSpinCount': Number of spins
                'recentSpins': Last 10 spins
            }
        
        Returns:
            {
                'signal': 'BET NOW' or 'WAIT',
                'numbers': Final 12/13 numbers to bet,
                'full_pool': All common numbers before filtering,
                'anchors': Anchor numbers,
                'confidence': 0-100%,
                'reasoning': Detailed explanation
            }
        """
        
        logging.info("="*80)
        logging.info("🎯 AI ENGINE V6 - NEW STRATEGY")
        logging.info("="*80)
        
        # Check if we have enough data
        if not self._has_sufficient_data(table_data):
            return self._return_wait("Insufficient data - need at least 3 spins")
        
        try:
            # STEP 1: Find pairs with consecutive hits from Table 3
            logging.info("\n" + "="*80)
            logging.info("STEP 1: FIND PAIRS WITH CONSECUTIVE HITS")
            logging.info("="*80)
            
            confirmed_pairs = self._find_confirmed_pairs(table_data['table3Hits'])
            
            if not confirmed_pairs:
                return self._return_wait("No confirmed pairs found in Table 3")
            
            # STEP 2: Select top 2 pairs
            logging.info("\n" + "="*80)
            logging.info("STEP 2: SELECT TOP 2 PAIRS")
            logging.info("="*80)
            
            top_2_pairs = self._select_top_2_pairs(confirmed_pairs)
            
            if len(top_2_pairs) < 2:
                return self._return_wait("Need at least 2 confirmed pairs")
            
            # STEP 3: Get NEXT row projections
            logging.info("\n" + "="*80)
            logging.info("STEP 3: GET NEXT ROW PROJECTIONS")
            logging.info("="*80)
            
            next_projections = table_data.get('table3NextProjections', {})
            
            if not next_projections:
                return self._return_wait("No NEXT row projections available")
            
            # STEP 4: Find common numbers
            logging.info("\n" + "="*80)
            logging.info("STEP 4: FIND COMMON NUMBERS")
            logging.info("="*80)
            
            common_numbers, selected_pairs = self._get_common_numbers(
                top_2_pairs, 
                next_projections, 
                confirmed_pairs
            )
            
            if not common_numbers:
                return self._return_wait("No common numbers found between top pairs")
            
            # STEP 5: Filter to 12 if needed
            logging.info("\n" + "="*80)
            logging.info("STEP 5: FILTER TO 12 NUMBERS (IF NEEDED)")
            logging.info("="*80)
            
            final_numbers, filtering_applied = self._filter_to_12(
                common_numbers,
                table_data.get('table1Hits', {}),
                table_data.get('table2Hits', {})
            )
            
            # STEP 6: Extract anchors
            logging.info("\n" + "="*80)
            logging.info("STEP 6: EXTRACT ANCHORS")
            logging.info("="*80)
            
            anchors = self._extract_anchors(
                final_numbers,
                next_projections,
                selected_pairs
            )
            
            # STEP 7: Calculate confidence
            logging.info("\n" + "="*80)
            logging.info("STEP 7: CALCULATE CONFIDENCE")
            logging.info("="*80)
            
            confidence = self._calculate_confidence(
                confirmed_pairs,
                selected_pairs,
                len(common_numbers),
                len(final_numbers),
                filtering_applied
            )
            
            # STEP 8: Make decision
            logging.info("\n" + "="*80)
            logging.info("STEP 8: MAKE DECISION")
            logging.info("="*80)
            
            signal = self._make_decision(confidence, confirmed_pairs, selected_pairs)
            
            # STEP 9: Prepare response
            response = {
                'signal': signal,
                'numbers': final_numbers,
                'full_pool': common_numbers,
                'anchors': anchors,
                'confidence': round(confidence, 2),
                'can_predict': True,
                'reasoning': {
                    'strategy': 'V6 - Common Numbers from Top 2 Pairs',
                    'selected_pairs': selected_pairs,
                    'pair1_hits': confirmed_pairs[selected_pairs[0]]['count'],
                    'pair2_hits': confirmed_pairs[selected_pairs[1]]['count'],
                    'common_pool_size': len(common_numbers),
                    'final_pool_size': len(final_numbers),
                    'filtering_applied': filtering_applied,
                    'consecutive_losses': self.consecutive_losses
                }
            }
            
            # Print decision summary
            self._print_decision_summary(response)
            
            return response
            
        except Exception as e:
            logging.error(f"❌ Error in prediction: {e}")
            import traceback
            traceback.print_exc()
            return self._return_wait(f"Error: {str(e)}")
    
    def _find_confirmed_pairs(self, table3_hits: Dict) -> Dict:
        """
        Find pairs with 2+ consecutive hits with consistent position codes
        
        Returns:
            {
                'prev': {'count': 3, 'hits': [...], 'priority': 5},
                'prevMinus1': {'count': 4, 'hits': [...], 'priority': 8},
                ...
            }
        """
        
        confirmed_pairs = {}
        
        # Check each projection type
        for proj_type in ['prev', 'prevPlus1', 'prevMinus1', 'prevPlus2', 'prevMinus2', 'prevPrev']:
            # Combine main and 13-opp hits (treat as one pair)
            main_hits = table3_hits.get(proj_type, [])
            opp_hits = table3_hits.get(f"{proj_type}_13opp", [])
            
            all_hits = main_hits + opp_hits
            
            if len(all_hits) < 2:
                continue
            
            # Sort by spin index
            all_hits.sort(key=lambda x: x['spinIdx'])
            
            # Find consecutive hits with consistent position codes
            consecutive_count = self._count_consecutive_consistent_hits(all_hits)
            
            if consecutive_count >= 2:
                priority_score = self._calculate_priority_score(all_hits)
                
                confirmed_pairs[proj_type] = {
                    'count': consecutive_count,
                    'hits': all_hits,
                    'priority': priority_score
                }
                
                logging.info(f"✅ {proj_type}: {consecutive_count} consecutive hits, priority={priority_score}")
                
                # Show pattern
                pattern = " → ".join([h['posCode'] for h in all_hits[-consecutive_count:]])
                logging.info(f"   Pattern: {pattern}")
        
        logging.info(f"\n📊 Total confirmed pairs: {len(confirmed_pairs)}")
        
        return confirmed_pairs
    
    def _count_consecutive_consistent_hits(self, hits: List[Dict]) -> int:
        """
        Count consecutive hits with consistent position codes (offset ≤ 1)
        """
        if len(hits) < 2:
            return len(hits)
        
        max_consecutive = 1
        current_consecutive = 1
        
        for i in range(1, len(hits)):
            prev_hit = hits[i-1]
            current_hit = hits[i]
            
            # Check if consecutive spin indices
            if current_hit['spinIdx'] == prev_hit['spinIdx'] + 1:
                # Check position code consistency
                if self._is_consistent_pattern(prev_hit['posCode'], current_hit['posCode']):
                    current_consecutive += 1
                    max_consecutive = max(max_consecutive, current_consecutive)
                else:
                    current_consecutive = 1
            else:
                current_consecutive = 1
        
        return max_consecutive
    
    def _is_consistent_pattern(self, code1: str, code2: str) -> bool:
        """
        Check if two position codes are consistent (offset change ≤ 1)
        
        Examples:
            OL+3 → OL+4: offset 3 → 4, diff = 1 ✅
            OL+3 → OR+3: offset 3 → 3, diff = 0 ✅
            OL+3 → OL+1: offset 3 → 1, diff = 2 ❌
        """
        
        # Extract offsets
        offset1 = self._extract_offset(code1)
        offset2 = self._extract_offset(code2)
        
        if offset1 is None or offset2 is None:
            return False
        
        offset_diff = abs(offset2 - offset1)
        
        return offset_diff <= 1
    
    def _extract_offset(self, code: str) -> Optional[int]:
        """
        Extract offset from position code
        
        Examples:
            'OL+3' → 3
            'S+0' → 0
            'SR-2' → 2
        """
        try:
            if '+' in code:
                return int(code.split('+')[1])
            elif '-' in code:
                return int(code.split('-')[1])
            else:
                return 0
        except:
            return None
    
    def _calculate_priority_score(self, hits: List[Dict]) -> int:
        """
        Calculate priority score based on position codes
        S+0, S±1, O+0, O±1 have highest priority
        """
        score = 0
        
        for hit in hits:
            code = hit['posCode']
            if code in self.HIGH_PRIORITY_PATTERNS:
                score += 10
            else:
                score += 1
        
        return score
    
    def _select_top_2_pairs(self, confirmed_pairs: Dict) -> List[str]:
        """
        Select top 2 pairs with most consecutive hits
        If tie, use priority score
        
        Returns:
            ['prevMinus1', 'prevMinus2']
        """
        
        pairs_with_scores = []
        
        for pair_name, data in confirmed_pairs.items():
            pairs_with_scores.append({
                'name': pair_name,
                'hits': data['count'],
                'priority': data['priority']
            })
        
        # Sort by: 1) hit count (desc), 2) priority (desc)
        pairs_with_scores.sort(key=lambda x: (x['hits'], x['priority']), reverse=True)
        
        # Take top 2
        top_2 = [p['name'] for p in pairs_with_scores[:2]]
        
        logging.info(f"\n🎯 SELECTED TOP 2 PAIRS:")
        for i, pair_data in enumerate(pairs_with_scores[:2], 1):
            logging.info(f"   #{i}: {pair_data['name']}")
            logging.info(f"       Consecutive hits: {pair_data['hits']}")
            logging.info(f"       Priority score: {pair_data['priority']}")
        
        return top_2
    
    def _get_common_numbers(
        self, 
        top_2_pairs: List[str],
        next_projections: Dict,
        confirmed_pairs: Dict
    ) -> Tuple[List[int], List[str]]:
        """
        Get common numbers between top 2 pairs' NEXT projections
        If no common numbers, use pair with fewer hits
        
        Returns:
            (common_numbers, selected_pairs)
        """
        
        pair1_name = top_2_pairs[0]
        pair2_name = top_2_pairs[1]
        
        # Get projections for next spin
        pair1_proj = next_projections.get(pair1_name, {}).get('numbers', [])
        pair2_proj = next_projections.get(pair2_name, {}).get('numbers', [])
        
        logging.info(f"\n📊 PAIR 1 ({pair1_name}) NEXT projections:")
        logging.info(f"   Numbers: {sorted(pair1_proj)}")
        logging.info(f"   Total: {len(pair1_proj)}")
        
        logging.info(f"\n📊 PAIR 2 ({pair2_name}) NEXT projections:")
        logging.info(f"   Numbers: {sorted(pair2_proj)}")
        logging.info(f"   Total: {len(pair2_proj)}")
        
        # Find intersection
        common = list(set(pair1_proj) & set(pair2_proj))
        common.sort()
        
        if common:
            logging.info(f"\n✅ COMMON NUMBERS FOUND:")
            logging.info(f"   Numbers: {common}")
            logging.info(f"   Total: {len(common)}")
            return common, [pair1_name, pair2_name]
        
        # No common numbers - use pair with fewer hits
        logging.info(f"\n⚠️  NO COMMON NUMBERS!")
        logging.info(f"   Using pair with fewer hits...")
        
        pair1_hits = confirmed_pairs[pair1_name]['count']
        pair2_hits = confirmed_pairs[pair2_name]['count']
        
        if pair1_hits < pair2_hits:
            logging.info(f"   Selected: {pair1_name} ({pair1_hits} hits < {pair2_hits} hits)")
            return pair1_proj, [pair1_name]
        else:
            logging.info(f"   Selected: {pair2_name} ({pair2_hits} hits < {pair1_hits} hits)")
            return pair2_proj, [pair2_name]
    
    def _filter_to_12(
        self,
        common_numbers: List[int],
        table1_hits: Dict,
        table2_hits: Dict
    ) -> Tuple[List[int], bool]:
        """
        Filter to 12 numbers using Table 1 & 2 if common > 12
        Otherwise return all common numbers
        
        Returns:
            (final_numbers, filtering_applied)
        """
        
        logging.info(f"\n📊 FILTERING DECISION:")
        logging.info(f"   Common pool size: {len(common_numbers)}")
        
        if len(common_numbers) <= 12:
            logging.info(f"   ✅ No filtering needed (≤ 12 numbers)")
            
            # Add 26 if 0 is present
            final = common_numbers.copy()
            if 0 in final and 26 not in final:
                final.append(26)
                logging.info(f"   🔄 Added 26 (0/26 pairing rule)")
            
            return final, False
        
        logging.info(f"   🔍 Filtering needed (> 12 numbers)")
        logging.info(f"   Using Table 1 & 2 hot columns...")
        
        # Find hot numbers from Table 1 & 2
        hot_numbers = self._find_hot_numbers_table1_and_2(table1_hits, table2_hits)
        
        # Keep only numbers in both common and hot
        filtered = [n for n in common_numbers if n in hot_numbers]
        
        logging.info(f"\n📊 FILTERING RESULTS:")
        logging.info(f"   Hot numbers from Table 1 & 2: {len(hot_numbers)}")
        logging.info(f"   After filtering: {len(filtered)}")
        
        if len(filtered) > 12:
            # Still too many - balance red/black
            filtered = self._balance_red_black(filtered, target=12)
            logging.info(f"   After red/black balance: {len(filtered)}")
        
        if len(filtered) < 12 and len(filtered) < len(common_numbers):
            # Add back some common numbers
            remaining = [n for n in common_numbers if n not in filtered]
            needed = min(12 - len(filtered), len(remaining))
            filtered.extend(remaining[:needed])
            logging.info(f"   Added back {needed} numbers to reach 12")
        
        # Add 26 if 0 is present
        if 0 in filtered and 26 not in filtered:
            filtered.append(26)
            logging.info(f"   🔄 Added 26 (0/26 pairing rule)")
        
        return filtered, True
    
    def _find_hot_numbers_table1_and_2(
        self,
        table1_hits: Dict,
        table2_hits: Dict
    ) -> Set[int]:
        """
        Find hot numbers from Table 1 & 2
        Table 1: 0+19 as one pair, check for 3+ consecutive hits
        Table 2: All pairs, check for 3+ consecutive hits
        """
        
        hot_numbers = set()
        
        # TABLE 1: Check 0+19 as ONE pair
        ref0_hits = table1_hits.get('ref0', [])
        ref19_hits = table1_hits.get('ref19', [])
        combined_0_19 = ref0_hits + ref19_hits
        
        if len(combined_0_19) >= 3:
            consecutive = self._count_consecutive_consistent_hits(combined_0_19)
            if consecutive >= 3:
                # Get all projection numbers from these hits
                for hit in combined_0_19:
                    hot_numbers.update(hit.get('betNumbers', []))
                logging.info(f"   ✅ Table 1: 0+19 pair has {consecutive} consecutive hits")
        
        # TABLE 1: Check prev, prevPlus1, prevMinus1 separately
        for proj_type in ['prev', 'prevPlus1', 'prevMinus1']:
            hits = table1_hits.get(proj_type, [])
            if len(hits) >= 3:
                consecutive = self._count_consecutive_consistent_hits(hits)
                if consecutive >= 3:
                    for hit in hits:
                        hot_numbers.update(hit.get('betNumbers', []))
                    logging.info(f"   ✅ Table 1: {proj_type} has {consecutive} consecutive hits")
        
        # TABLE 2: Check all pairs
        for proj_type in table2_hits.keys():
            hits = table2_hits.get(proj_type, [])
            if len(hits) >= 3:
                consecutive = self._count_consecutive_consistent_hits(hits)
                if consecutive >= 3:
                    for hit in hits:
                        hot_numbers.update(hit.get('betNumbers', []))
                    logging.info(f"   ✅ Table 2: {proj_type} has {consecutive} consecutive hits")
        
        return hot_numbers
    
    def _balance_red_black(self, numbers: List[int], target: int = 12) -> List[int]:
        """
        Balance red/black numbers while keeping closest to target
        """
        # Simple implementation: just take first 'target' numbers
        # Can be enhanced with actual red/black balancing
        return numbers[:target]
    
    def _extract_anchors(
        self,
        final_numbers: List[int],
        next_projections: Dict,
        selected_pairs: List[str]
    ) -> List[int]:
        """
        Extract anchor numbers from the final numbers
        Anchors are the purple/green base numbers (not neighbors)
        """
        
        anchors = []
        
        for pair_name in selected_pairs:
            pair_data = next_projections.get(pair_name, {})
            pair_anchors = pair_data.get('anchors', [])
            
            # Keep only anchors that are in final numbers
            for anchor in pair_anchors:
                if anchor in final_numbers and anchor not in anchors:
                    anchors.append(anchor)
        
        anchors.sort()
        
        logging.info(f"\n⭐ ANCHORS IDENTIFIED:")
        logging.info(f"   Anchors: {anchors}")
        logging.info(f"   Total: {len(anchors)}")
        
        loose = [n for n in final_numbers if n not in anchors]
        logging.info(f"\n💗 LOOSE NUMBERS:")
        logging.info(f"   Numbers: {loose}")
        logging.info(f"   Total: {len(loose)}")
        
        return anchors
    
    def _calculate_confidence(
        self,
        confirmed_pairs: Dict,
        selected_pairs: List[str],
        common_pool_size: int,
        final_pool_size: int,
        filtering_applied: bool
    ) -> float:
        """
        Calculate confidence based on new strategy factors
        """
        
        confidence = 70.0  # Base
        
        # Check for priority patterns
        has_priority = False
        for pair_name in selected_pairs:
            hits = confirmed_pairs[pair_name]['hits']
            for hit in hits:
                if hit['posCode'] in self.HIGH_PRIORITY_PATTERNS:
                    has_priority = True
                    break
        
        if has_priority:
            confidence += 15
            logging.info(f"   +15% Priority patterns (S+0, O+0, etc.)")
        
        # Multiple confirmations
        if len(confirmed_pairs) > 2:
            confidence += 10
            logging.info(f"   +10% Multiple confirmations ({len(confirmed_pairs)} pairs)")
        
        # High consecutive hits (4+)
        max_hits = max([data['count'] for data in confirmed_pairs.values()])
        if max_hits >= 4:
            confidence += 5
            logging.info(f"   +5% High consecutive hits ({max_hits})")
        
        # Penalty for consecutive losses
        if self.consecutive_losses > 0:
            penalty = min(self.consecutive_losses * 5, 25)
            confidence -= penalty
            logging.info(f"   -{penalty}% Consecutive losses ({self.consecutive_losses})")
        
        # Cap at 95%
        confidence = min(confidence, 95.0)
        
        logging.info(f"\n📊 FINAL CONFIDENCE: {confidence}%")
        
        return confidence
    
    def _make_decision(self, confidence: float, confirmed_pairs: Dict, selected_pairs: List[str]) -> str:
        """
        Make betting decision based on new rules:
        1. 70%+ → BET NOW
        2. < 70% → WAIT
        3. 3 losses in a row → Need 80%+
        4. Lost $1000+ → Need 90%+ AND golden patterns
        """
        
        logging.info(f"\n📊 DECISION LOGIC:")
        logging.info(f"   Base confidence: {confidence}%")
        logging.info(f"   Consecutive losses: {self.consecutive_losses}")
        logging.info(f"   Total session loss: ${self.total_session_loss:.2f}")
        
        # Check for golden patterns (S+0, S±1, O+0, O±1)
        has_golden = self._has_golden_patterns(confirmed_pairs, selected_pairs)
        logging.info(f"   Has golden patterns: {has_golden}")
        
        # RULE 4: Lost $1000+ → Need 90%+ AND golden patterns
        if self.total_session_loss >= 1000:
            logging.info(f"\n⚠️  EMERGENCY MODE: Lost ${self.total_session_loss:.2f} >= $1000")
            if confidence >= 90.0 and has_golden:
                logging.info(f"✅ DECISION: BET NOW (90%+ confidence AND golden patterns)")
                return "BET NOW"
            else:
                reason = []
                if confidence < 90.0:
                    reason.append(f"confidence {confidence}% < 90%")
                if not has_golden:
                    reason.append("no golden patterns")
                logging.info(f"⏸️  DECISION: WAIT ({', '.join(reason)})")
                return "WAIT"
        
        # RULE 3: 3 losses in a row → Need 80%+
        if self.consecutive_losses >= 3:
            logging.info(f"\n⚠️  CAUTION MODE: {self.consecutive_losses} consecutive losses")
            if confidence >= 80.0:
                logging.info(f"✅ DECISION: BET NOW (80%+ confidence after losses)")
                return "BET NOW"
            else:
                logging.info(f"⏸️  DECISION: WAIT (confidence {confidence}% < 80%)")
                return "WAIT"
        
        # RULE 1 & 2: Normal mode
        if confidence >= 70.0:
            logging.info(f"\n✅ DECISION: BET NOW (confidence {confidence}% >= 70%)")
            return "BET NOW"
        else:
            logging.info(f"\n⏸️  DECISION: WAIT (confidence {confidence}% < 70%)")
            return "WAIT"

    def _has_golden_patterns(self, confirmed_pairs: Dict, selected_pairs: List[str]) -> bool:
        """
        Check if selected pairs have golden patterns (S+0, S±1, O+0, O±1)
        """
        for pair_name in selected_pairs:
            if pair_name not in confirmed_pairs:
                continue
            
            hits = confirmed_pairs[pair_name]['hits']
            for hit in hits:
                if hit['posCode'] in self.GOLDEN_PATTERNS:
                    return True
        
        return False
    
    def _print_decision_summary(self, response: Dict):
        """
        Print a beautiful boxed summary
        """
        
        logging.info("\n")
        logging.info("╔" + "="*78 + "╗")
        logging.info("║" + " "*25 + "📊 DECISION SUMMARY" + " "*34 + "║")
        logging.info("╠" + "="*78 + "╣")
        
        reasoning = response['reasoning']
        
        logging.info("║ 1️⃣  SELECTED PAIRS:" + " "*58 + "║")
        logging.info(f"║    Pair 1: {reasoning['selected_pairs'][0]:<15} ({reasoning['pair1_hits']} consecutive hits)" + " "*(78-len(f"    Pair 1: {reasoning['selected_pairs'][0]:<15} ({reasoning['pair1_hits']} consecutive hits)")) + "║")
        
        if len(reasoning['selected_pairs']) > 1:
            logging.info(f"║    Pair 2: {reasoning['selected_pairs'][1]:<15} ({reasoning['pair2_hits']} consecutive hits)" + " "*(78-len(f"    Pair 2: {reasoning['selected_pairs'][1]:<15} ({reasoning['pair2_hits']} consecutive hits)")) + "║")
        
        logging.info("╠" + "="*78 + "╣")
        logging.info(f"║ 2️⃣  COMMON POOL: {reasoning['common_pool_size']} numbers" + " "*(78-len(f"2️⃣  COMMON POOL: {reasoning['common_pool_size']} numbers")) + "║")
        logging.info(f"║    Numbers: {str(response['full_pool']):<60}║")
        
        logging.info("╠" + "="*78 + "╣")
        logging.info(f"║ 3️⃣  FINAL NUMBERS: {reasoning['final_pool_size']} numbers" + " "*(78-len(f"3️⃣  FINAL NUMBERS: {reasoning['final_pool_size']} numbers")) + "║")
        logging.info(f"║    Numbers: {str(response['numbers']):<60}║")
        logging.info(f"║    Anchors: {str(response['anchors']):<60}║")
        
        logging.info("╠" + "="*78 + "╣")
        logging.info(f"║ 4️⃣  DECISION:" + " "*64 + "║")
        logging.info(f"║    Signal: {response['signal']:<15} Confidence: {response['confidence']}%" + " "*(78-len(f"    Signal: {response['signal']:<15} Confidence: {response['confidence']}%")) + "║")
        
        logging.info("╚" + "="*78 + "╝")
    
    def _has_sufficient_data(self, table_data: Dict) -> bool:
        """Check if we have enough data to make a prediction"""
        return table_data.get('currentSpinCount', 0) >= 3
    
    def _return_wait(self, reason: str) -> Dict:
        """Return WAIT signal with reason"""
        logging.info(f"\n⏸️  WAIT: {reason}")
        
        return {
            'signal': 'WAIT',
            'numbers': [],
            'full_pool': [],
            'anchors': [],
            'confidence': 0,
            'can_predict': False,
            'reasoning': {
                'reason': reason
            }
        }
    
    def process_result(self, hit: bool, bet_amount: float = 0, profit_loss: float = 0):
        """
        Update streak tracking and session loss after a bet result
        
        Args:
            hit: Whether the bet won
            bet_amount: Total amount bet
            profit_loss: Net profit/loss for this bet (negative = loss)
        """
        if hit:
            self.consecutive_wins += 1
            self.consecutive_losses = 0
            logging.info(f"✅ HIT! Consecutive wins: {self.consecutive_wins}")
            
            # Reduce session loss if we won
            if profit_loss > 0:
                self.total_session_loss = max(0, self.total_session_loss - profit_loss)
                logging.info(f"💰 Session loss reduced to: ${self.total_session_loss:.2f}")
        else:
            self.consecutive_losses += 1
            self.consecutive_wins = 0
            logging.info(f"❌ MISS! Consecutive losses: {self.consecutive_losses}")
            
            # Increase session loss
            if profit_loss < 0:
                self.total_session_loss += abs(profit_loss)
                logging.info(f"💸 Session loss increased to: ${self.total_session_loss:.2f}")


# Create singleton instance
engine = AIEngineV6()


def predict(table_data: Dict) -> Dict:
    """
    Main entry point for predictions
    """
    return engine.predict(table_data)


def process_result(hit: bool, bet_amount: float = 0, profit_loss: float = 0):
    """
    Process bet result
    """
    engine.process_result(hit, bet_amount, profit_loss)


if __name__ == "__main__":
    print("AI Engine V6 - NEW STRATEGY")
    print("Ready to receive predictions!")
