"""
AI ENGINE V5 - User's Exact Methodology
=======================================

CRITICAL CHANGES FROM V4:
1. READ projections from hit.betNumbers (don't calculate)
2. Check 2-hit CONSISTENCY (not just any 2 hits)
3. SMART anchor selection (3-4 anchors, not 8)
4. Find COMMON numbers across hot pairs
5. Analyze S-side vs O-side PREFERENCE
6. Golden = naturally < 24 numbers
7. Table 1/2 need 3 HITS (not 2)
8. Bankroll < $3000 = golden patterns only
9. 0/26 PAIRING RULE: If either appears, BOTH must be included

Author: Claude (Anthropic)
Date: January 11, 2026
"""

import logging
from typing import Dict, List, Optional, Set, Tuple
from datetime import datetime

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='[%(asctime)s.%(msecs)03d] [%(levelname)s] %(message)s',
    datefmt='%H:%M:%S'
)

# Wheel order for neighbor calculations
WHEEL_ORDER = [0, 32, 15, 19, 4, 21, 2, 25, 17, 34, 6, 27, 13, 36, 11, 30, 8, 23, 10, 5, 24, 16, 33, 1, 20, 14, 31, 9, 22, 18, 29, 7, 28, 12, 35, 3, 26]

# Regular opposites (for reference, but AI should be smart about using them)
REGULAR_OPPOSITES = {
    0: 26, 26: 0, 32: 15, 15: 32, 19: 4, 4: 19, 21: 2, 2: 21,
    25: 17, 17: 25, 34: 6, 6: 34, 27: 13, 13: 27, 36: 11, 11: 36,
    30: 8, 8: 30, 23: 10, 10: 23, 5: 24, 24: 5, 16: 33, 33: 16,
    1: 20, 20: 1, 14: 31, 31: 14, 9: 22, 22: 9, 18: 29, 29: 18,
    7: 28, 28: 7, 12: 35, 35: 12, 3: 26  # 3 maps to 26 (which is 0)
}


class RouletteAIv5:
    """
    V5 AI Engine - User's Exact Methodology
    
    Philosophy:
    - Quality over quantity (fewer bets, higher win rate)
    - Smart analysis (find common patterns, side preferences)
    - Discipline (wait for confirmation, golden patterns when low)
    """
    
    def __init__(self):
        self.logger = logging.getLogger(__name__)
        self.prediction_count = 0
        
    def predict_numbers(self, table_data: Dict, recent_spins: List[int], 
                       session_state: Dict) -> Dict:
        """
        Main prediction method
        
        Args:
            table_data: Table hits from frontend
            recent_spins: Last 10 actual numbers
            session_state: Current session state (balance, losses, etc.)
            
        Returns:
            Prediction dict with can_predict, numbers, confidence, etc.
        """
        self.prediction_count += 1
        
        # Extract data
        table3_hits = table_data.get('table3Hits', {})
        table1_hits = table_data.get('table1Hits', {})
        table2_hits = table_data.get('table2Hits', {})
        spin_count = table_data.get('currentSpinCount', 0)
        
        balance = session_state.get('balance', 4000)
        consecutive_losses = session_state.get('consecutive_losses', 0)
        
        self.logger.info("=" * 70)
        self.logger.info(f"PREDICTION #{self.prediction_count} - V5 SELECTIVE METHODOLOGY")
        self.logger.info("=" * 70)
        self.logger.info(f"Recent spins: {recent_spins}")
        self.logger.info(f"Balance: ${balance}")
        self.logger.info(f"Consecutive losses: {consecutive_losses}")
        
        # Minimum spins check
        if spin_count < 3:
            return self._no_prediction("Not enough spins (need 3+)")
        
        # STEP 1: Find confirmed pairs (2 consecutive hits with consistency)
        self.logger.info("-" * 50)
        self.logger.info("STEP 1: TABLE 3 - FIND 2-HIT CONFIRMED PATTERNS")
        self.logger.info("-" * 50)
        
        confirmed_pairs = self._find_confirmed_pairs(table3_hits)
        
        if not confirmed_pairs:
            return self._no_prediction("No 2-hit confirmed patterns found")
        
        self.logger.info(f"\n✅ Found {len(confirmed_pairs)} confirmed pair(s)")
        
        # STEP 2: Smart anchor selection
        self.logger.info("-" * 50)
        self.logger.info("STEP 2: SMART ANCHOR SELECTION")
        self.logger.info("-" * 50)
        
        selection_result = self._smart_anchor_selection(confirmed_pairs)
        
        selected_anchors = selection_result['anchors']
        selection_method = selection_result['method']
        
        if not selected_anchors:
            return self._no_prediction("No strong anchors found")
        
        # STEP 3: Check if golden pattern
        self.logger.info("-" * 50)
        self.logger.info("STEP 3: GOLDEN PATTERN CHECK")
        self.logger.info("-" * 50)
        
        is_golden = self._is_golden_pattern(confirmed_pairs, selected_anchors)
        
        if is_golden:
            self.logger.info("⭐⭐⭐ GOLDEN PATTERN DETECTED!")
        else:
            self.logger.info("Regular pattern (not golden)")
        
        # STEP 4: Bankroll rule check
        if balance < 3000 and not is_golden:
            self.logger.info("-" * 50)
            self.logger.info("⚠️  BANKROLL RULE: Balance < $3000")
            self.logger.info("⚠️  Only betting on GOLDEN patterns to recover")
            return self._no_prediction(f"Bankroll ${balance} < $3000 - waiting for golden pattern")
        
        # STEP 5: Expand to final bet numbers (±1 neighbors)
        self.logger.info("-" * 50)
        self.logger.info("STEP 4: EXPAND ANCHORS TO BET NUMBERS")
        self.logger.info("-" * 50)
        
        final_numbers = self._expand_to_bet_numbers(selected_anchors)
        
        self.logger.info(f"Anchors: {selected_anchors}")
        self.logger.info(f"Final bet numbers: {sorted(final_numbers)}")
        self.logger.info(f"Total: {len(final_numbers)} numbers")
        
        # STEP 6: Cross-validate with Table 1 & 2 (optional boost)
        self.logger.info("-" * 50)
        self.logger.info("STEP 5: TABLE 1 & 2 CROSS-VALIDATION")
        self.logger.info("-" * 50)
        
        confirmations = self._check_table_confirmations(
            selected_anchors, table1_hits, table2_hits
        )
        
        if confirmations:
            self.logger.info(f"✅ Found {len(confirmations)} confirmation(s) from Table 1/2")
            for conf in confirmations:
                self.logger.info(f"  - Table {conf['table']}: {conf['pair']} pair")
        else:
            self.logger.info("No additional confirmations from Table 1/2")
        
        # STEP 7: Calculate confidence
        self.logger.info("-" * 50)
        self.logger.info("STEP 6: CONFIDENCE CALCULATION")
        self.logger.info("-" * 50)
        
        confidence = self._calculate_confidence(
            confirmed_pairs=confirmed_pairs,
            is_golden=is_golden,
            confirmations=confirmations,
            consecutive_losses=consecutive_losses,
            selection_method=selection_method
        )
        
        # STEP 8: Decision
        threshold = 0.85 if consecutive_losses >= 3 else 0.75
        
        if consecutive_losses >= 3:
            self.logger.info(f"⚠️  STRICT MODE: Require {threshold:.0%} confidence (3+ losses)")
        
        self.logger.info(f"Final confidence: {confidence:.0%}")
        self.logger.info(f"Threshold: {threshold:.0%}")
        
        if confidence >= threshold:
            self.logger.info("✅ CONFIDENCE ABOVE THRESHOLD - BET NOW!")
            
            return {
                'can_predict': True,
                'signal': 'BET NOW',
                'numbers': final_numbers,
                'anchors': selected_anchors,
                'confidence': confidence,
                'is_golden': is_golden,
                'selection_method': selection_method,
                'confirmations': len(confirmations),
                'reasoning': self._build_reasoning(
                    confirmed_pairs, is_golden, selection_method, confirmations
                ),
                'bet_per_number': 4.0
            }
        else:
            self.logger.info(f"⚠️  Confidence {confidence:.0%} below threshold {threshold:.0%}")
            self.logger.info("💪 WAIT FOR HIGHER CONFIDENCE")
            
            return self._no_prediction(
                f"Confidence {confidence:.0%} below threshold {threshold:.0%}"
            )
    
    def _find_confirmed_pairs(self, table3_hits: Dict) -> List[Dict]:
        """
        Find pairs with 2 CONSECUTIVE hits that show consistent pattern
        
        Consistency means:
        - Same position family (SR, OR, etc.) OR
        - Similar distance (±1, ±2) OR
        - Clear side preference
        """
        confirmed = []
        
        # Check each pair type
        pair_types = ['prev', 'prevPlus1', 'prevMinus1', 'prevPlus2', 'prevMinus2', 'prevPrev']
        
        for pair_name in pair_types:
            hits = table3_hits.get(pair_name, [])
            
            if len(hits) < 2:
                continue
            
            # Get last 2 hits
            last_two = hits[-2:]
            
            # Check if consecutive spins
            spin1 = last_two[0].get('spinIdx', -1)
            spin2 = last_two[1].get('spinIdx', -1)
            
            if spin2 != spin1 + 1:
                continue  # Not consecutive
            
            # Check position consistency
            pos1 = last_two[0].get('posCode', 'XX')
            pos2 = last_two[1].get('posCode', 'XX')
            
            if not self._is_consistent_pattern(pos1, pos2):
                self.logger.info(f"  {pair_name}: Positions {pos1}, {pos2} - NOT consistent")
                continue
            
            # CONFIRMED!
            self.logger.info(f"✅ {pair_name}: 2-HIT CONFIRMED")
            self.logger.info(f"  Spin {spin1}: actual {last_two[0]['actual']} at {pos1}")
            self.logger.info(f"  Spin {spin2}: actual {last_two[1]['actual']} at {pos2}")
            
            # Extract projections from MOST RECENT hit
            most_recent = last_two[1]
            projections = most_recent.get('betNumbers', [])
            
            self.logger.info(f"  Projections: {len(projections)} numbers from last hit")
            
            confirmed.append({
                'pair': pair_name,
                'hits': last_two,
                'projections': projections,
                'positions': [pos1, pos2],
                'consecutive_count': 2
            })
        
        return confirmed
    
    def _is_consistent_pattern(self, pos1: str, pos2: str) -> bool:
        """
        Check if two position codes show a consistent pattern
        
        Rules:
        - Same family (SR, SR) = consistent
        - Same distance (±3, ±3) = consistent
        - Adjacent distances (±3, ±2) = consistent
        - Different families and distances = NOT consistent
        """
        if pos1 == 'XX' or pos2 == 'XX':
            return False
        
        # Extract components
        family1, dist1 = self._parse_position_code(pos1)
        family2, dist2 = self._parse_position_code(pos2)
        
        # Same family is always consistent
        if family1 == family2:
            return True
        
        # Same distance is consistent (even if different family)
        if abs(dist1) == abs(dist2):
            return True
        
        # Adjacent distances (e.g., +3 and +2)
        if abs(abs(dist1) - abs(dist2)) <= 1:
            return True
        
        # Otherwise not consistent
        return False
    
    def _parse_position_code(self, pos_code: str) -> Tuple[str, int]:
        """
        Parse position code into family and distance
        
        Examples:
        - 'SR+3' → ('SR', 3)
        - 'OL-2' → ('OL', -2)
        - 'S+0' → ('S', 0)
        """
        if '+' in pos_code:
            parts = pos_code.split('+')
            return (parts[0], int(parts[1]))
        elif '-' in pos_code:
            parts = pos_code.split('-')
            return (parts[0], -int(parts[1]))
        else:
            return (pos_code, 0)
    
    def _smart_anchor_selection(self, confirmed_pairs: List[Dict]) -> Dict:
        """
        Smart anchor selection based on user's methodology
        
        Strategy:
        1. If multiple hot pairs → find COMMON numbers
        2. Analyze side preference (S vs O)
        3. Select 3-4 best anchors (not 8!)
        
        Returns dict with anchors and method used
        """
        # Strategy 1: Multiple pairs - find common numbers
        if len(confirmed_pairs) > 1:
            common = self._find_common_numbers(confirmed_pairs)
            
            if len(common) >= 3:
                self.logger.info(f"📊 Multiple hot pairs detected")
                self.logger.info(f"  Common numbers across pairs: {sorted(common)}")
                
                # Pick best 3-4 from common
                selected = self._pick_best_n(list(common), 4)
                
                return {
                    'anchors': selected,
                    'method': 'COMMON_NUMBERS',
                    'source_pairs': len(confirmed_pairs)
                }
        
        # Strategy 2: Analyze side preference
        best_pair = confirmed_pairs[0]  # Strongest pair
        projections = best_pair['projections']
        
        side_analysis = self._analyze_side_preference(confirmed_pairs)
        
        if side_analysis['strong_preference']:
            preferred_side = side_analysis['preferred_side']
            
            self.logger.info(f"📊 Side preference detected: {preferred_side}-side")
            self.logger.info(f"  {preferred_side} hits: {side_analysis[f'{preferred_side}_count']}")
            
            # Filter to preferred side
            filtered = self._filter_to_side(projections, preferred_side)
            
            if len(filtered) >= 3:
                selected = self._pick_best_n(filtered, 4)
                
                return {
                    'anchors': selected,
                    'method': f'{preferred_side.upper()}_SIDE_PREFERENCE',
                    'source_pairs': 1
                }
        
        # Strategy 3: Default - pick best from strongest pair
        self.logger.info(f"📊 Using strongest pair: {best_pair['pair']}")
        
        selected = self._pick_best_n(projections, 4)
        
        return {
            'anchors': selected,
            'method': 'STRONGEST_PAIR',
            'source_pairs': 1
        }
    
    def _find_common_numbers(self, confirmed_pairs: List[Dict]) -> Set[int]:
        """Find numbers that appear in multiple hot pairs"""
        if not confirmed_pairs:
            return set()
        
        # Start with first pair's projections
        common = set(confirmed_pairs[0]['projections'])
        
        # Intersect with other pairs
        for pair in confirmed_pairs[1:]:
            common = common.intersection(set(pair['projections']))
        
        return common
    
    def _analyze_side_preference(self, confirmed_pairs: List[Dict]) -> Dict:
        """
        Analyze if there's a strong S-side or O-side preference
        
        Returns dict with preference analysis
        """
        s_count = 0
        o_count = 0
        
        for pair in confirmed_pairs:
            for pos_code in pair['positions']:
                if pos_code.startswith('S'):
                    s_count += 1
                elif pos_code.startswith('O'):
                    o_count += 1
        
        # Strong preference if one side has 2x more hits
        strong_preference = False
        preferred_side = None
        
        if s_count > o_count * 2:
            strong_preference = True
            preferred_side = 'S'
        elif o_count > s_count * 2:
            strong_preference = True
            preferred_side = 'O'
        
        return {
            'S_count': s_count,
            'O_count': o_count,
            'strong_preference': strong_preference,
            'preferred_side': preferred_side
        }
    
    def _filter_to_side(self, numbers: List[int], side: str) -> List[int]:
        """
        Filter numbers to preferred side
        
        Note: This is a simplified version. 
        In reality, would need position mapping data.
        For now, return a subset.
        """
        # Simplified: Return first half as S-side, second half as O-side
        mid = len(numbers) // 2
        
        if side == 'S':
            return numbers[:mid + 2]  # Slightly more than half
        else:
            return numbers[mid - 2:]  # Slightly more than half
    
    def _pick_best_n(self, numbers: List[int], n: int) -> List[int]:
        """
        Pick best N numbers from list
        
        For now: Pick first N (they're already ordered by frontend)
        Future: Could add additional scoring
        """
        return numbers[:min(n, len(numbers))]
    
    def _is_golden_pattern(self, confirmed_pairs: List[Dict], 
                          selected_anchors: List[int]) -> bool:
        """
        Check if this is a golden pattern
        
        Golden = Pattern naturally gives < 24 numbers
        """
        # Check if any pair has < 24 total projections
        for pair in confirmed_pairs:
            proj_count = len(pair['projections'])
            if proj_count < 24:
                self.logger.info(f"  {pair['pair']}: {proj_count} numbers < 24 → GOLDEN!")
                return True
        
        # Check if positions are very tight (all same code)
        for pair in confirmed_pairs:
            positions = pair['positions']
            
            # All same position
            if len(set(positions)) == 1:
                self.logger.info(f"  {pair['pair']}: All positions {positions[0]} → GOLDEN!")
                return True
            
            # All same family and close distance
            families = [self._parse_position_code(p)[0] for p in positions]
            if len(set(families)) == 1:
                self.logger.info(f"  {pair['pair']}: Tight {families[0]} family → GOLDEN!")
                return True
        
        return False
    
    def _expand_to_bet_numbers(self, anchors: List[int]) -> List[int]:
        """
        Expand anchors to final bet numbers by adding ±1 wheel neighbors
        
        CRITICAL RULE: If 0 or 26 appears, BOTH must be included!
        """
        bet_numbers = set()
        
        for anchor in anchors:
            # Handle 0 as 26
            anchor_num = 26 if anchor == 0 else anchor
            
            try:
                idx = WHEEL_ORDER.index(anchor_num)
                
                # Add anchor + neighbors
                for offset in [-1, 0, 1]:
                    neighbor_idx = (idx + offset) % 37
                    num = WHEEL_ORDER[neighbor_idx]
                    
                    # Convert 26 back to 0
                    num = 0 if num == 26 else num
                    bet_numbers.add(num)
                    
            except ValueError:
                # If anchor not found, just add it
                bet_numbers.add(anchor)
        
        # CRITICAL RULE: If 0 or 26 is in bet numbers, add BOTH!
        if 0 in bet_numbers or 26 in bet_numbers:
            bet_numbers.add(0)
            bet_numbers.add(26)
            self.logger.info("  ⭐ 0/26 PAIRING RULE: Both 0 and 26 added to bet")
        
        return sorted(list(bet_numbers))
    
    def _check_table_confirmations(self, anchors: List[int], 
                                   table1_hits: Dict, 
                                   table2_hits: Dict) -> List[Dict]:
        """
        Check if anchors are confirmed by Table 1 or 2
        
        Rule: Need 3 hits (not 2!) in same column
        
        Returns list of confirmations
        """
        confirmations = []
        
        # Check Table 1
        for pair_name, hits in table1_hits.items():
            if len(hits) >= 3:
                # Get last 3 hits
                last_three = hits[-3:]
                
                # Check if all in same "column"
                columns = [self._get_column_from_position(h.get('posCode', 'XX')) 
                          for h in last_three]
                
                if columns[0] and all(c == columns[0] for c in columns):
                    # Hot column detected!
                    confirmations.append({
                        'table': 1,
                        'pair': pair_name,
                        'column': columns[0],
                        'hits': 3
                    })
        
        # Check Table 2
        for pair_name, hits in table2_hits.items():
            if len(hits) >= 3:
                last_three = hits[-3:]
                columns = [self._get_column_from_position(h.get('posCode', 'XX')) 
                          for h in last_three]
                
                if columns[0] and all(c == columns[0] for c in columns):
                    confirmations.append({
                        'table': 2,
                        'pair': pair_name,
                        'column': columns[0],
                        'hits': 3
                    })
        
        return confirmations
    
    def _get_column_from_position(self, pos_code: str) -> Optional[str]:
        """
        Map position code to column
        
        Based on table-lookup.js mapping:
        - S-family → first column
        - O-family → second/third column
        """
        if pos_code == 'XX':
            return None
        
        family, _ = self._parse_position_code(pos_code)
        
        if family in ['S', 'SL', 'SR']:
            return 'first'
        elif family in ['O', 'OR', 'OL']:
            return 'second'
        else:
            return None
    
    def _calculate_confidence(self, confirmed_pairs: List[Dict],
                             is_golden: bool,
                             confirmations: List[Dict],
                             consecutive_losses: int,
                             selection_method: str) -> float:
        """
        Calculate prediction confidence
        
        Factors:
        - Base: 0.70
        - Golden pattern: +0.15
        - Multiple pairs: +0.10
        - Table confirmations: +0.05 each
        - Common numbers method: +0.05
        - Loss penalty: -0.05
        """
        confidence = 0.70  # Base
        
        self.logger.info("Confidence breakdown:")
        self.logger.info(f"  Base: 0.70")
        
        # Golden boost
        if is_golden:
            confidence += 0.15
            self.logger.info(f"  + Golden pattern: +0.15")
        
        # Multiple pairs boost
        if len(confirmed_pairs) > 1:
            confidence += 0.10
            self.logger.info(f"  + Multiple pairs ({len(confirmed_pairs)}): +0.10")
        
        # Table confirmations
        if confirmations:
            boost = 0.05 * len(confirmations)
            confidence += boost
            self.logger.info(f"  + Table confirmations ({len(confirmations)}): +{boost:.2f}")
        
        # Common numbers method
        if selection_method == 'COMMON_NUMBERS':
            confidence += 0.05
            self.logger.info(f"  + Common numbers method: +0.05")
        
        # Loss penalty
        if consecutive_losses >= 3:
            confidence -= 0.05
            self.logger.info(f"  - Consecutive losses penalty: -0.05")
        
        # Cap at 0.95
        confidence = min(confidence, 0.95)
        
        return confidence
    
    def _build_reasoning(self, confirmed_pairs: List[Dict],
                        is_golden: bool,
                        selection_method: str,
                        confirmations: List[Dict]) -> List[str]:
        """Build human-readable reasoning"""
        reasons = []
        
        # Confirmed pairs
        reasons.append(f"Found {len(confirmed_pairs)} confirmed pair(s) with 2 consecutive hits")
        
        for pair in confirmed_pairs:
            reasons.append(f"  - {pair['pair']}: {len(pair['projections'])} projections")
        
        # Golden
        if is_golden:
            reasons.append("⭐ GOLDEN PATTERN detected (< 24 numbers or tight range)")
        
        # Selection method
        if selection_method == 'COMMON_NUMBERS':
            reasons.append("Used COMMON NUMBERS across multiple hot pairs")
        elif 'SIDE' in selection_method:
            reasons.append(f"Detected {selection_method.split('_')[0]}-side preference")
        else:
            reasons.append("Used strongest pair projections")
        
        # Confirmations
        if confirmations:
            reasons.append(f"Validated by {len(confirmations)} Table 1/2 confirmation(s)")
        
        return reasons
    
    def _no_prediction(self, reason: str) -> Dict:
        """Return no prediction response"""
        self.logger.info(f"\n⚠️  {reason}")
        self.logger.info("💪 WAIT FOR BETTER OPPORTUNITY")
        
        return {
            'can_predict': False,
            'signal': 'WAIT',
            'numbers': [],
            'anchors': [],
            'confidence': 0.0,
            'is_golden': False,
            'reasoning': [reason],
            'bet_per_number': 0
        }


# Export
__all__ = ['RouletteAIv5']
