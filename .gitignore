# European Roulette Tracker - .gitignore
# Comprehensive ignore file for Node.js + Python project

# ============================================
# NODE.JS / ELECTRON
# ============================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Production builds
dist/
build/
out/
release/

# Electron specific
*.dmg
*.exe
*.app
*.deb
*.rpm

# ============================================
# PYTHON
# ============================================

# Virtual Environment
python-env/
venv/
env/
ENV/
.venv/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# PyCharm
.idea/

# Spyder
.spyderproject
.spyproject

# ============================================
# DATA FILES (Keep structure, ignore content)
# ============================================

# Session data (user-generated, can be large)
shared/data/*.json
shared/data/*.csv

# Exports (user-generated)
shared/exports/*.csv
shared/exports/*.pdf
shared/exports/*.xlsx

# But keep the directory structure
!shared/data/.gitkeep
!shared/exports/.gitkeep
!shared/configs/.gitkeep

# Logs
shared/logs/*.log
logs/*.log
*.log

# Temporary data files
*.tmp
*.temp
*.bak
*.swp
*.swo

# Large model files (Phase 2 ML models)
backend/models/*.h5
backend/models/*.pkl
backend/models/*.joblib
backend/models/*.pb
backend/models/saved_model/

# Training data
backend/training_data/*.csv
backend/training_data/*.json

# ============================================
# IDE / EDITOR
# ============================================

# VSCode
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Sublime Text
*.sublime-project
*.sublime-workspace

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ============================================
# OPERATING SYSTEM
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
.directory
.Trash-*
.nfs*

# ============================================
# ENVIRONMENT & CONFIG
# ============================================

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# Config files with secrets
config.local.yaml
secrets.yaml
credentials.json

# ============================================
# BACKUP & TEMPORARY
# ============================================

# Backups
*.backup
*.old
*_backup
*_old
app_old/

# Compressed files
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# But allow the release zip if needed
!releases/*.zip

# ============================================
# TESTING
# ============================================

# Test results
test-results/
junit.xml
.nyc_output/

# ============================================
# DOCUMENTATION
# ============================================

# Generated documentation
docs/_build/
site/

# But keep important docs
!docs/*.md
!README.md
!CHANGELOG.md

# ============================================
# MISC
# ============================================

# Lock files (optional - some teams commit these)
# Uncomment if you don't want to commit lock files
# yarn.lock
# poetry.lock
# Pipfile.lock

# Thumbnails
*.jpg.thumb
*.png.thumb

# Database
*.db
*.sqlite
*.sqlite3

# Certificate files (never commit these!)
*.pem
*.key
*.cert
*.crt
*.p12

# ============================================
# PROJECT SPECIFIC
# ============================================

# Don't commit installed dependencies
node_modules/
python-env/

# Don't commit user session data
shared/data/session-*.json
shared/data/roulette-session-*.json

# Don't commit exports
shared/exports/export-*.csv
shared/exports/roulette-export-*.csv

# Keep example files
!shared/data/example-session.json
!shared/exports/example-export.csv

# Keep README files in directories
!**/README.md

# ============================================
# DEPLOYMENT
# ============================================

# Deployment configs (may contain secrets)
.deployment
deploy.sh

# Cloud credentials
.aws/
.gcloud/
.azure/

# ============================================
# END OF .gitignore
# ============================================

# To force-add a file that's ignored:
# git add -f filename

# To see what's being ignored:
# git status --ignored
